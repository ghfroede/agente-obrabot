{
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "webhookUrl": "${OBRABOT_API_URL}/api/v1/openclaw/telegram-event"
    }
  },
  "skills": {
    "paths": ["./openclaw/skills"]
  },
  "agents": {
    "ceo": {
      "workspace": "./openclaw/agents/ceo",
      "model": "${OPENAI_MODEL}",
      "skills": ["ingestao-telegram", "triagem-obra"]
    }
  },
  "backend": {
    "baseUrl": "${OBRABOT_API_URL}",
    "hmac": {
      "enabled": true,
      "secret": "${OPENCLAW_SHARED_SECRET}",
      "signatureHeader": "X-OpenClaw-Signature",
      "timestampHeader": "X-OpenClaw-Timestamp",
      "eventIdHeader": "X-OpenClaw-Event-Id"
    }
  }
}
