# Application
APP_ENV=development
NODE_ENV=development
AGENT_NAME=Obrabot
AGENT_SYSTEM_PROMPT=Você é o agente CEO da Construtora AgentOS (Obrabot). Orquestre triagem e classificação de entradas de engenheiros de obra.

# API
PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=*

# Database
DATABASE_URL=postgresql+asyncpg://obrabot:obrabot@localhost:5432/obrabot

# Redis / Queue
REDIS_URL=redis://localhost:6379/0

# OpenClaw webhook
OPENCLAW_SHARED_SECRET=change-me-in-production
OPENCLAW_REQUIRE_HMAC=false
OPENCLAW_MAX_CLOCK_SKEW_SECONDS=300
WEBHOOK_MAX_BODY_BYTES=10485760

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_THREAD_IDS=
ENABLE_TELEGRAM_FILE_DOWNLOAD=true

# Rate limit (Redis)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_USER_PER_MINUTE=30
RATE_LIMIT_CHAT_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60

# Media size limits (bytes)
MAX_IMAGE_BYTES=10485760
MAX_AUDIO_BYTES=26214400
MAX_DOCUMENT_BYTES=52428800

# LLM (OpenAI SDK)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_BASE_URL=https://api.openai.com/v1

# Local bucket fallback (dev/tests)
LOCAL_BUCKET_PATH=.local-bucket
TEMPLATES_DIR=src/templates

# S3-compatible storage (MEGA S4) — optional for local dev
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=bucket-construtora
S3_REGION=us-east-1
