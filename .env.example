# Application
NODE_ENV=development
AGENT_NAME=Obrabot
AGENT_SYSTEM_PROMPT=Você é o agente CEO da Construtora AgentOS (Obrabot). Orquestre triagem e classificação de entradas de engenheiros de obra.

# API
PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=*

# Database
DATABASE_URL=postgresql+asyncpg://obrabot:obrabot@localhost:5432/obrabot

# Redis / Queue
REDIS_URL=redis://localhost:6379/0

# LLM (OpenAI-compatible)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# S3-compatible storage (MEGA S4) — optional for local dev
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=bucket-construtora
S3_REGION=us-east-1
